from calibre.web.feeds.news import BasicNewsRecipe

class CustomDailyDigest(BasicNewsRecipe):
    title          = 'Daily Digest- News, Hobbies & Sports'
    description    = 'Custom aggregated news feed covering world events, woodworking, hunting, grilling, and education.'
    oldest_article = 7.0             # Fetches articles up to 7 days old
    max_articles_per_feed = 10       # Maximum articles per individual section feed
    auto_cleanup   = True            # Automatically strips ads and webpage cruft
    language       = 'en'

    # Structured multi-section feed list
    feeds = [
        # News Section
        ('News- CSM USA', 'https://www.csmonitor.com/rss/feeds/usa.rss'),
        ('News- CSM World', 'https://www.csmonitor.com/rss/feeds/world.rss'),
        
        # Hunting Section
        ('Hunting- Petersen Small Game', 'https://www.petersenshunting.com/rss/small-game'),
        
        # Cooking Section
        ('Cooking- AmazingRibs', 'https://amazingribs.com/rss'),
        
        # Home Section
        ('Home- Sweeten Stories', 'https://sweeten.com/blog/feed/'),
        
        # Education Section
        ('Education- Chronicle of Higher Ed', 'https://www.chronicle.com/page/rss-feeds'),
        
        # Sports Section
        ('Sports- Football Reference Blog', 'https://www.sports-reference.com/blog/feed/'), # Safe trailing comma
    ]
