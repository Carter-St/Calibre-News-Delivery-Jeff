from calibre.web.feeds.news import BasicNewsRecipe

class CustomDailyDigest(BasicNewsRecipe):
    title          = 'Daily Digest - News, Hobbies and Sports'
    description    = 'Custom aggregated news feed covering world events, woodworking, hunting, grilling, and education.'
    oldest_article = 7.0             
    max_articles_per_feed = 10       
    auto_cleanup   = True            
    language       = 'en'

    # Just define the list here. Do not add a parse_index loop below it!
    feeds = [
        ('News: CSM All Stories', 'https://www.csmonitor.com/rss/feeds/all.rss'),
        ('Hunting: Petersen Small Game', 'https://www.petersenshunting.com/listing/hunting-small-game/172350?format=rss'),
        ('Cooking: AmazingRibs', 'https://amazingribs.com/rss'),
        ('Home: Sweeten Stories', 'https://sweeten.com/blog/feed/'),
        ('Education: Chronicle of Higher Ed', 'https://www.chronicle.com/page/rss-feeds'),
        ('Sports: Football Reference Blog', 'https://www.sports-reference.com/blog/feed/'),
    ]
