from calibre.web.feeds.news import BasicNewsRecipe

class CustomDailyDigest(BasicNewsRecipe):
    title          = 'Daily Digest - News, Hobbies and Sports'
    description    = 'Custom aggregated news feed covering world events, woodworking, hunting, grilling, and education.'
    oldest_article = 7.0             
    max_articles_per_feed = 10       
    language       = 'en'
    
    # RELAX THE SCRAPER: Allow Calibre to read standard embedded RSS summary content 
    # This prevents Cloudflare from throwing 403 Forbidden errors on GitHub runners
    has_embedded_content = True     
    auto_cleanup         = True

    # Firewalls bypass configuration for feeds that require basic handshake elements
    get_browser_user_agent = lambda x: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64; x64) Chrome/124.0.0.0 Safari/537.36'
    
    # RE-ENGINEERED FEED TARGETS
    feeds = [
        # News Section: Using CSM's absolute dedicated RSS edge distribution endpoint
        ('News: CSM All Stories', 'http://rss.csmonitor.com/feeds/top'),
        
        # Hunting Section: Reverted to direct small game XML endpoint to strip out database junk
        ('Hunting: Petersen Small Game', 'https://www.petersenshunting.com/rss/small-game'),
        
        # Cooking Section
        ('Cooking: AmazingRibs', 'https://amazingribs.com/rss'),
        
        # Home Section
        ('Home: Sweeten Stories', 'https://sweeten.com/blog/feed/'),
        
        # Education Section
        ('Education: Chronicle of Higher Ed', 'https://www.chronicle.com/page/rss-feeds'),
        
        # Sports Section
        ('Sports: Football Reference Blog', 'https://www.sports-reference.com/blog/feed/'),
    ]
