class MyNewspaper(BasicNewsRecipe):
    title          = 'My Daily Newspaper'
    oldest_article = 7            # Keeps articles up to 7 days old
    max_articles_per_feed = 100   # Maximum number of stories to grab
    auto_cleanup   = True

    # Check this list carefully!
    feeds          = [
        ('Economics', 'https://www.economist.com/latest/rss.xml '),
        ('USA News', 'https://thehill.com/homenews/feed/'),
        ('World News', 'https://feeds.bbci.co.uk/news/rss.xml?edition=int'),
        ('Sports Headlines', 'https://www.cbssports.com/rss/headlines/')
    ]
